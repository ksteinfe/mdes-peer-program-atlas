LLM_PROVIDER=openai
LLM_MODEL=
LLM_API_KEY=

# Optional: OpenAI-compatible base URL (proxies, Azure-style gateways)
LLM_BASE_URL=

# Tavily (required for peer-atlas add-program)
TAVILY_API_KEY=

# Optional: HTTP fetch cache (default: repo .peer-atlas/url-cache/, TTL 48h; JSON files are pretty-printed)
# Each entry stores simplified HTML in ``body`` plus optional ``body_markdown`` (LLM main-content extract, JSON-safe).
# PEER_ATLAS_FETCH_CACHE_DIR=
# PEER_ATLAS_FETCH_CACHE_TTL_SECONDS=172800
# Skip the extra LLM that turns simplified HTML into main-body Markdown for evidence (default: run when LLM is configured).
# PEER_ATLAS_SKIP_HTML_MARKDOWN_LLM=1
# Max characters of ``body`` sent into that HTML→Markdown model (default 120_000, clamped 8_000–500_000).
# PEER_ATLAS_HTML_MARKDOWN_LLM_INPUT_CHARS=
# Hard cap (chars) on one downloaded / cached page string (default ~32 MiB).
# PEER_ATLAS_FETCH_MAX_CHARS=
# For per-URL limits >= 50_000, bump up to at least this many chars (default ~8 MiB).
# PEER_ATLAS_FETCH_EVIDENCE_FLOOR_CHARS=
# Retries for direct page GET (403/401/429), then alternate minimal headers:
# PEER_ATLAS_FETCH_RETRIES=3
# PEER_ATLAS_FETCH_RETRY_DELAY_MS=500

# Optional: Cookie header for HTTP fetches (Playwright + httpx fallback; e.g. gated .edu pages).
# PEER_ATLAS_FETCH_COOKIE=

# Playwright: after pip install, run `playwright install chromium` so page fetches use real Chromium.
# Optional: headed browser for debugging (slower).
# PEER_ATLAS_PLAYWRIGHT_HEADED=1
# After domcontentloaded, wait for a content-region selector + text stability before page.content():
# PEER_ATLAS_PLAYWRIGHT_POST_LOAD_SECONDS=12
# Milliseconds between inner_text samples for stability (default 200).
# PEER_ATLAS_PLAYWRIGHT_STABLE_INTERVAL_MS=250
# After stability, scroll main into view and to page bottom before snapshot (default on). Set 0 to skip.
# PEER_ATLAS_PLAYWRIGHT_SCROLL_MAIN=0

# Optional: on LLM/validation failures, dump full raw + parsed JSON (default: short preview only).
# PEER_ATLAS_LLM_DEBUG=1

# Latest `peer-atlas` LLM traffic is logged under .peer-atlas/llm-last-session/ as numbered step-slug files (cleared each CLI run; no env var).