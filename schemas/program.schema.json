{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdes-peer-program-atlas.local/schemas/program.schema.json",
  "title": "Program",
  "type": "object",
  "required": [
    "program_id",
    "base_url",
    "date_added",
    "date_updated",
    "llm_rationales",
    "identity",
    "positioning",
    "duration",
    "degree_cost",
    "curriculum",
    "verification"
  ],
  "additionalProperties": false,
  "properties": {
    "program_id": { "type": "string", "minLength": 1 },
    "base_url": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical program site URL used for ingest and evidence (https recommended)."
    },
    "date_added": {
      "type": "string",
      "minLength": 1,
      "description": "UTC timestamp when the program was first added to the corpus (ISO 8601, e.g. 2026-05-03T12:00:00Z)."
    },
    "date_updated": {
      "type": "string",
      "minLength": 1,
      "description": "UTC timestamp of the last corpus write that modified this program (ISO 8601)."
    },
    "llm_rationales": {
      "type": "array",
      "items": { "$ref": "#/$defs/llmRationale" }
    },
    "identity": { "$ref": "#/$defs/identity" },
    "positioning": { "$ref": "#/$defs/positioning" },
    "duration": { "$ref": "#/$defs/duration" },
    "degree_cost": { "$ref": "#/$defs/degreeCost" },
    "curriculum": { "$ref": "#/$defs/curriculum" },
    "verification": { "$ref": "#/$defs/verification" }
  },
  "$defs": {
    "llmRationale": {
      "type": "object",
      "required": [
        "feature",
        "source_url",
        "note",
        "llm_title",
        "retrieved_date"
      ],
      "additionalProperties": false,
      "properties": {
        "feature": {
          "type": "string",
          "description": "Dot path of the program field this rationale supports (e.g. degree_cost.comparison_cost_usd)."
        },
        "source_url": {
          "type": "string",
          "description": "Canonical URL of the fetched page this row cites."
        },
        "note": {
          "type": "string",
          "description": "Why this source supports the feature, inference steps, or uncertainty."
        },
        "llm_title": {
          "type": "string",
          "description": "Short human-readable label for the cited URL (e.g. Program fees page)."
        },
        "retrieved_date": {
          "type": "string",
          "description": "ISO or human date the content was retrieved; use empty string if unknown."
        }
      }
    },
    "identity": {
      "type": "object",
      "required": [
        "institution_name",
        "program_name",
        "credential_name",
        "degree_type",
        "host_academic_units",
        "host_academic_model",
        "location_label"
      ],
      "additionalProperties": false,
      "properties": {
        "institution_name": { "type": "string" },
        "program_name": { "type": "string" },
        "credential_name": { "type": "string" },
        "degree_type": { "type": "string" },
        "host_academic_units": {
          "type": "array",
          "items": { "type": "string" }
        },
        "host_academic_model": { "type": "string" },
        "location_label": {
          "type": "string",
          "description": "Human-readable location (city, region, country as appropriate)."
        }
      }
    },
    "positioning": {
      "type": "object",
      "required": ["positioning_summary", "positioning_tags"],
      "additionalProperties": false,
      "properties": {
        "positioning_summary": { "type": "string" },
        "positioning_tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "duration": {
      "type": "object",
      "required": ["length_in_berkeley_semesters", "duration_category"],
      "additionalProperties": false,
      "properties": {
        "length_in_berkeley_semesters": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "duration_category": { "type": "string" }
      }
    },
    "degreeCost": {
      "type": "object",
      "required": [
        "base_currency",
        "exchange_rate_to_usd",
        "comparison_cost_usd",
        "total_degree_cost_base_currency"
      ],
      "additionalProperties": false,
      "properties": {
        "base_currency": { "type": "string" },
        "exchange_rate_to_usd": { "type": ["number", "null"] },
        "comparison_cost_usd": { "type": ["number", "null"] },
        "total_degree_cost_base_currency": { "type": ["number", "null"] }
      }
    },
    "coreCourse": {
      "type": "object",
      "required": [
        "course_id",
        "course_title",
        "units_or_credits",
        "sequence_position",
        "primary_type",
        "secondary_type",
        "course_summary",
        "source_url",
        "learning_outcomes"
      ],
      "additionalProperties": false,
      "properties": {
        "course_id": { "type": "string" },
        "course_title": { "type": "string" },
        "units_or_credits": { "type": ["number", "null"] },
        "normalized_unit_weight": { "type": ["number", "null"] },
        "sequence_position": { "type": ["integer", "null"] },
        "primary_type": { "type": "string" },
        "secondary_type": { "type": ["string", "null"] },
        "course_summary": { "type": "string" },
        "source_url": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "learning_outcomes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "curriculumElectives": {
      "type": "object",
      "required": ["summary", "estimated_elective_course_count"],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "description": "Concise human-readable description of elective structure (not machine-readable constraints)."
        },
        "estimated_elective_course_count": {
          "type": ["integer", "null"],
          "description": "Rough integer count of elective courses/slots for visualization."
        }
      }
    },
    "curriculum": {
      "type": "object",
      "required": [
        "unit_system",
        "sequencedness",
        "curriculum_summary",
        "offers_specialization",
        "core_courses",
        "electives"
      ],
      "additionalProperties": false,
      "properties": {
        "unit_system": { "type": "string" },
        "sequencedness": { "type": "string" },
        "curriculum_summary": { "type": "string" },
        "offers_specialization": {
          "type": ["boolean", "null"],
          "description": "True when the program offers distinct tracks, concentrations, or specializations students choose among."
        },
        "core_courses": {
          "type": "array",
          "items": { "$ref": "#/$defs/coreCourse" }
        },
        "electives": { "$ref": "#/$defs/curriculumElectives" }
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "verified_by", "verified_date"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string" },
        "verified_by": { "type": "string" },
        "verified_date": { "type": "string" }
      }
    }
  }
}
