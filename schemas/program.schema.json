{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdes-peer-program-atlas.local/schemas/program.schema.json",
  "title": "Program",
  "type": "object",
  "required": [
    "program_id",
    "base_url",
    "sources",
    "llm_rationales",
    "identity",
    "positioning",
    "duration",
    "degree_cost",
    "curriculum",
    "verification"
  ],
  "additionalProperties": false,
  "properties": {
    "program_id": { "type": "string", "minLength": 1 },
    "base_url": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical program site URL used for ingest and evidence (https recommended)."
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "llm_rationales": {
      "type": "array",
      "items": { "$ref": "#/$defs/llmRationale" }
    },
    "identity": { "$ref": "#/$defs/identity" },
    "positioning": { "$ref": "#/$defs/positioning" },
    "duration": { "$ref": "#/$defs/duration" },
    "degree_cost": { "$ref": "#/$defs/degreeCost" },
    "curriculum": { "$ref": "#/$defs/curriculum" },
    "verification": { "$ref": "#/$defs/verification" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "url",
        "llm_title",
        "llm_summary",
        "retrieved_date"
      ],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "llm_title": {
          "type": "string",
          "description": "Short human-readable label for this URL (e.g. Program 'About' page)."
        },
        "llm_summary": { "type": "string" },
        "retrieved_date": { "type": "string" }
      }
    },
    "llmRationale": {
      "type": "object",
      "required": ["feature", "source_url", "note"],
      "additionalProperties": false,
      "properties": {
        "feature": { "type": "string" },
        "source_url": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "identity": {
      "type": "object",
      "required": [
        "institution_name",
        "program_name",
        "credential_name",
        "degree_type",
        "host_academic_units",
        "host_academic_model",
        "location_label"
      ],
      "additionalProperties": false,
      "properties": {
        "institution_name": { "type": "string" },
        "program_name": { "type": "string" },
        "credential_name": { "type": "string" },
        "degree_type": { "type": "string" },
        "host_academic_units": {
          "type": "array",
          "items": { "type": "string" }
        },
        "host_academic_model": { "type": "string" },
        "location_label": {
          "type": "string",
          "description": "Human-readable location (city, region, country as appropriate)."
        }
      }
    },
    "positioning": {
      "type": "object",
      "required": ["positioning_summary", "positioning_tags"],
      "additionalProperties": false,
      "properties": {
        "positioning_summary": { "type": "string" },
        "positioning_tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "duration": {
      "type": "object",
      "required": ["length_in_berkeley_semesters", "duration_category"],
      "additionalProperties": false,
      "properties": {
        "length_in_berkeley_semesters": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "duration_category": { "type": "string" }
      }
    },
    "degreeCost": {
      "type": "object",
      "required": [
        "base_currency",
        "exchange_rate_to_usd",
        "comparison_cost_usd",
        "total_degree_cost_base_currency"
      ],
      "additionalProperties": false,
      "properties": {
        "base_currency": { "type": "string" },
        "exchange_rate_to_usd": { "type": ["number", "null"] },
        "comparison_cost_usd": { "type": ["number", "null"] },
        "total_degree_cost_base_currency": { "type": ["number", "null"] }
      }
    },
    "coreCourse": {
      "type": "object",
      "required": [
        "course_id",
        "course_title",
        "units_or_credits",
        "sequence_position",
        "primary_type",
        "secondary_type",
        "course_summary",
        "source_url",
        "learning_outcomes"
      ],
      "additionalProperties": false,
      "properties": {
        "course_id": { "type": "string" },
        "course_title": { "type": "string" },
        "units_or_credits": { "type": ["number", "null"] },
        "normalized_unit_weight": { "type": ["number", "null"] },
        "sequence_position": { "type": ["integer", "null"] },
        "primary_type": { "type": "string" },
        "secondary_type": { "type": ["string", "null"] },
        "course_summary": { "type": "string" },
        "source_url": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "learning_outcomes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "electiveCourseLite": {
      "type": "object",
      "required": ["course_id"],
      "additionalProperties": false,
      "properties": {
        "course_id": { "type": "string" },
        "units_or_credits": { "type": ["number", "null"] },
        "normalized_unit_weight": { "type": ["number", "null"] }
      }
    },
    "curriculum": {
      "type": "object",
      "required": [
        "unit_system",
        "sequencedness",
        "curriculum_summary",
        "offers_specialization",
        "evidence_curriculum_summary",
        "core_courses",
        "elective_requirements",
        "elective_courses"
      ],
      "additionalProperties": false,
      "properties": {
        "unit_system": { "type": "string" },
        "sequencedness": { "type": "string" },
        "curriculum_summary": { "type": "string" },
        "offers_specialization": {
          "type": "boolean",
          "description": "True when the program offers distinct tracks, concentrations, or specializations students choose among."
        },
        "evidence_curriculum_summary": {
          "type": "string",
          "description": "Human-readable digest of fetched evidence—core courses with codes, term placement when known, how electives work, and related detail. Length is not capped; for reference only, not a legal guarantee."
        },
        "core_courses": {
          "type": "array",
          "items": { "$ref": "#/$defs/coreCourse" }
        },
        "elective_requirements": {
          "type": "string",
          "description": "Human-readable summary of how electives work (policy text)."
        },
        "elective_courses": {
          "type": "array",
          "items": { "$ref": "#/$defs/electiveCourseLite" }
        }
      }
    },
    "verification": {
      "type": "object",
      "required": ["status", "verified_by", "verified_date"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string" },
        "verified_by": { "type": "string" },
        "verified_date": { "type": "string" }
      }
    }
  }
}
