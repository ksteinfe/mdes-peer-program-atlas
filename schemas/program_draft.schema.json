{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdes-peer-program-atlas.local/schemas/program_draft.schema.json",
  "title": "Program (ingest draft)",
  "type": "object",
  "required": [
    "program_id",
    "base_url",
    "date_added",
    "date_updated",
    "atlas_ingest",
    "sources",
    "llm_rationales",
    "identity",
    "positioning",
    "duration",
    "degree_cost",
    "curriculum",
    "historical",
    "verification"
  ],
  "additionalProperties": false,
  "properties": {
    "program_id": { "type": "string", "minLength": 1 },
    "base_url": { "type": "string", "minLength": 1 },
    "date_added": {
      "type": "string",
      "minLength": 1,
      "description": "UTC when first added (ISO 8601)."
    },
    "date_updated": {
      "type": "string",
      "minLength": 1,
      "description": "UTC of last modification during ingest (ISO 8601)."
    },
    "atlas_ingest": {
      "type": "object",
      "required": ["stage", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "skeleton",
            "search_context",
            "positioning",
            "duration",
            "degree_cost",
            "curriculum",
            "curriculum_digest",
            "curriculum_overview",
            "curriculum_courses",
            "curriculum_course_research",
            "curriculum_course_llm",
            "identity",
            "historical",
            "complete"
          ]
        },
        "updated_at": { "type": "string" }
      }
    },
    "sources": {
      "type": "array",
      "description": "Normalized URLs from url-cache whose registrable domain matches base_url (draft may start empty).",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "atlas_search_context": {
      "type": "object",
      "description": "Draft-only: Tavily query hints from seed URL LLM; stripped before publish.",
      "additionalProperties": false,
      "properties": {
        "official_program_label": { "type": "string" },
        "short_institution": { "type": "string" },
        "degree_subject_keywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "llm_rationales": {
      "type": "array",
      "items": { "$ref": "#/$defs/llmRationale" }
    },
    "identity": { "$ref": "#/$defs/identity" },
    "positioning": { "$ref": "#/$defs/positioning" },
    "duration": { "$ref": "#/$defs/duration" },
    "degree_cost": { "$ref": "#/$defs/degreeCost" },
    "curriculum": { "$ref": "#/$defs/curriculum" },
    "historical": { "$ref": "#/$defs/historical" },
    "verification": { "$ref": "#/$defs/verification" }
  },
  "$defs": {
    "llmRationale": {
      "type": "object",
      "required": [
        "feature",
        "source_url",
        "note",
        "llm_title",
        "retrieved_date"
      ],
      "additionalProperties": false,
      "properties": {
        "feature": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] },
        "note": { "type": ["string", "null"] },
        "llm_title": { "type": ["string", "null"] },
        "retrieved_date": { "type": ["string", "null"] }
      }
    },
    "identity": {
      "type": "object",
      "required": [
        "institution_name",
        "program_name",
        "credential_name",
        "degree_type",
        "host_academic_units",
        "host_academic_model",
        "location_label",
        "first_degree_granted_year"
      ],
      "additionalProperties": false,
      "properties": {
        "institution_name": { "type": ["string", "null"] },
        "program_name": { "type": ["string", "null"] },
        "credential_name": { "type": ["string", "null"] },
        "degree_type": { "type": ["string", "null"] },
        "host_academic_units": {
          "type": "array",
          "items": { "type": "string" }
        },
        "host_academic_model": { "type": ["string", "null"] },
        "location_label": { "type": ["string", "null"] },
        "first_degree_granted_year": {
          "type": ["string", "null"],
          "description": "First calendar year the program granted a degree. Use 'unknown' when unpublished. Null during ingest."
        },
        "cip_code": {
          "type": ["string", "null"],
          "description": "Best-matching 6-digit CIP 2020 code. Use 'unknown' when not determinable. Null during ingest."
        },
        "ipeds_unitid": {
          "type": ["string", "null"],
          "description": "IPEDS UnitID of the host institution (6-digit string, e.g. '110635'). Null for international institutions or when unmatched."
        }
      }
    },
    "positioning": {
      "type": "object",
      "required": ["positioning_summary", "positioning_tags"],
      "additionalProperties": false,
      "properties": {
        "positioning_summary": { "type": ["string", "null"] },
        "positioning_tags": {
          "type": "array",
          "items": { "type": ["string", "null"] }
        }
      }
    },
    "duration": {
      "type": "object",
      "required": ["length_in_berkeley_semesters", "duration_category"],
      "additionalProperties": false,
      "properties": {
        "length_in_berkeley_semesters": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "duration_category": { "type": ["string", "null"] }
      }
    },
    "degreeCost": {
      "type": "object",
      "required": [
        "base_currency",
        "exchange_rate_to_usd",
        "comparison_cost_usd",
        "cost_base_currency"
      ],
      "additionalProperties": false,
      "properties": {
        "base_currency": { "type": ["string", "null"] },
        "exchange_rate_to_usd": { "type": ["number", "null"] },
        "comparison_cost_usd": {
          "type": ["number", "null"],
          "description": "Tuition plus mandatory program/academic fees only (USD), for cross-program comparison—not housing or full cost of attendance."
        },
        "cost_base_currency": {
          "type": ["number", "null"],
          "description": "Program-stated tuition total in base_currency, including mandatory program/academic fees when they are part of that tuition-and-fees subtotal; exclude housing and full cost of attendance."
        }
      }
    },
    "coreCourse": {
      "type": "object",
      "required": [
        "course_id",
        "course_title",
        "units_or_credits",
        "sequence_position",
        "primary_type",
        "secondary_type",
        "course_summary",
        "source_url",
        "learning_outcomes"
      ],
      "additionalProperties": false,
      "properties": {
        "course_id": { "type": "string" },
        "course_title": { "type": "string" },
        "units_or_credits": { "type": ["number", "null"] },
        "normalized_unit_weight": { "type": ["number", "null"] },
        "sequence_position": { "type": ["integer", "null"] },
        "primary_type": { "type": ["string", "null"] },
        "secondary_type": { "type": ["string", "null"] },
        "course_summary": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] },
        "learning_outcomes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "curriculumElectives": {
      "type": "object",
      "required": ["summary", "estimated_elective_course_count"],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "description": "Concise human-readable description of elective structure (not machine-readable constraints)."
        },
        "estimated_elective_course_count": {
          "type": ["integer", "null"],
          "description": "Rough integer count of elective courses/slots for visualization."
        }
      }
    },
    "curriculum": {
      "type": "object",
      "required": [
        "unit_system",
        "sequencedness",
        "curriculum_summary",
        "offers_specialization",
        "core_courses",
        "electives"
      ],
      "additionalProperties": false,
      "properties": {
        "unit_system": { "type": ["string", "null"] },
        "sequencedness": { "type": ["string", "null"] },
        "curriculum_summary": { "type": ["string", "null"] },
        "offers_specialization": {
          "type": ["boolean", "null"],
          "description": "True when the program offers distinct tracks, concentrations, or specializations students choose among."
        },
        "core_courses": {
          "type": "array",
          "items": { "$ref": "#/$defs/coreCourse" }
        },
        "electives": { "$ref": "#/$defs/curriculumElectives" }
      }
    },
    "historicalEntry": {
      "type": "object",
      "required": ["academic_year", "degrees_granted"],
      "additionalProperties": false,
      "properties": {
        "academic_year": {
          "type": ["string", "null"],
          "description": "Academic year label (e.g. '2022-23')."
        },
        "degrees_granted": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of degrees granted by the program in this academic year."
        }
      }
    },
    "historical": {
      "type": "array",
      "description": "Year-by-year degrees-granted data. Each entry covers one academic year. An empty array is valid when no data has been collected.",
      "items": { "$ref": "#/$defs/historicalEntry" }
    },
    "verification": {
      "type": "object",
      "required": ["status", "verified_by", "verified_date"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": ["string", "null"] },
        "verified_by": { "type": ["string", "null"] },
        "verified_date": { "type": ["string", "null"] }
      }
    }
  }
}
